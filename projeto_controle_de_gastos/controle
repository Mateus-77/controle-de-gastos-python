gastos = []
categorias_disponiveis = ['Alimentação', 'Transporte', 'Saúde', 'Lazer', 'Educação', 'Outros']
executando = True  #variavel de controle para sair do programa e do loop 
while executando:
    print('=' * 40)
    print('          Relatório de gastos        ')
    print('=' * 40)
    print('[1] Adicionar gastos')                     #TABELA VISUAL PARA O USUARIO EM LOOP
    print('[2] Relatorio Geral')
    print('[3] Listar por categoria')
    print('[4] Sair')
    print('[5] Excluir gasto')
    servico = input('Escolha o serviço que voce quer: ')

    if servico == '1':
        produto = (input('Digite o nome do produto:   ')).strip() #remover espaços vazios, nao permitindo o usuario salvar sem nome
        while not produto:     #pequena repetiçao para nao permitir espaços vazios
            print('Nome näo pode ser em branco')
            produto = input('Digite o nome do produto: ').strip()

        while True:
            try:
                valor_do_produto = float(input('Digite o preço do seu produto:   ')) #while para rodar o programa em loop caso o usuario coloque letras ao inver de numeros no preço
                break
            except ValueError:
                print('digite apenas números')
        
        if valor_do_produto <= 0:    #Validando se o valor e positivo ou negativo
            print('valor inválido')
        else:
            print('\ncategorias_disponiveis:')
            for i, cat in enumerate(categorias_disponiveis, 1): #cat == categoria
                print(f' [{i}] {cat}')
    
            escolha_a_categoria = input(f'Escolha a categoria (numero): ')

            if escolha_a_categoria.isdigit() and 1 <= int(escolha_a_categoria) <= len(categorias_disponiveis): #evitando erro de abc
                categoria = categorias_disponiveis[int(escolha_a_categoria) - 1]

            else:  
                categoria = 'Outros'
                print('Categoria invalida, defina como outros. ')

            gastos.append((produto, valor_do_produto,categoria))
            print('Gastos adicionados')

    elif servico == "2":
        print('=' * 30)
        print('LISTA DE GASTOS')
        print('=' * 30)

        if not gastos:
            print('Nenhum gasto cadastrado.')

        else:
            for i, (produto, valor, categoria) in enumerate(gastos, 1):
                print(f'{i}. {produto} [{categoria}] - R$ {valor:.2f}')

            print(f'Total de gastos cadastrados: {len(gastos)}') #total de gastos

            total = 0
            for item in gastos:
                total += item[1]

            media = total / len(gastos) #mostra as medias do gasto

            maior = gastos[0]  #funçao para mostrar o maior gasto
            for item in gastos:
                if item[1] > maior[1]:
                    maior = item

            print(f'Total gasto: R$ {total:.2f}')
            print(f'Média dos gastos: R$ {media:.2f}')
            print(f'Maior gasto: {maior[0]} - R$ {maior[1]:.2f}')

    elif servico == '3':
        if not gastos:
            print('Nenhum gasto cadastrado.') #saida para nenhum gasto encontrado
        else:
            for categoria in categorias_disponiveis:
                gastos_da_categoria = []             #criando a lista nova gastos_da_categoria
                for produto, valor, cat in gastos:
                    if cat == categoria:
                        gastos_da_categoria.append((produto, valor))
        
                                                 # fora do for acima so executa depois de ver todos os gastos
                if gastos_da_categoria:
                    total_categoria = sum(valor for _, valor in gastos_da_categoria)
                    print(f'\n{categoria} — Total: R$ {total_categoria:.2f}')
                    print('-' * 35)
                    for nome, valor in gastos_da_categoria:
                        print(f'  {nome:<22} R$ {valor:.2f}')

    elif servico == '4':
        
        while True:

            sair=input('Deseja sair? S/N').strip().upper()

            if sair == 'S':
                print('Encerrando o sistema')
                executando = False
                break

            elif sair =='N':
                print('Voltando ao menu')
                break
            else:
                print('Valor nao encontrado. Digite S ou N')

    elif servico == '5':
        if not gastos:
            print('Nenhum gasto cadastrado.')

        else:
            print('=' * 30)
            print('EXCLUIR GASTO')
            print('=' * 30)

            for i, (produto, valor, categoria) in enumerate(gastos,1): 
             print(f'{i}. {produto} [{categoria}] - R$ {valor:.2f}')

            escolha = input('Escolha o que deseja excluir:')

            if escolha.isdigit():
                indice = int(escolha) -1

                if 0 <= indice < len(gastos):
                    removido = gastos[indice]
                    del gastos[indice]
                    print(f'Gasto "{removido[0]}" foi removido com sucesso.')
                else:
                    print('Número inválido.')
            else:
                print('Digite apenas números.')

    else:
        print('Serviço näo encontrado, digite um numero compativel com os nossos serviços: ')